function detectAdBlock(cb) {
    const bait = document.createElement("div");
    bait.className = "adsbox ad adsense ad-banner";
    bait.style.position = "absolute";
    bait.style.height = "1px";
    bait.style.left = "-999px";
    document.body.appendChild(bait);

    setTimeout(() => {
        const blocked = bait.offsetHeight === 0;
        bait.remove();
        cb(blocked);
    }, 100);
}

function classifyZeroStatus(domain, adblock) {
    if (adblock) return "Blocked by adblocker";
    if (!navigator.onLine) return "Offline / no internet";
    if (domain.startsWith("http://") && location.protocol === "https:")
        return "Blocked mixed-content (HTTP on HTTPS page)";
    return "Blocked by CORS, DNS failure, or network error";
}

function getIPGeo() {
    return $.getJSON("https://ipapi.co/json/");
}

function testDomains(domains) {
    const device = getDeviceInfo();

    detectAdBlock(function(adblock) {
        getIPGeo().done(function(geo) {
            let results = [];
            let completed = 0;

            domains.forEach(function(domain) {
                $.ajax({
                    url: domain,
                    type: "HEAD",
                    timeout: 5000,
                    success: function(_, _, xhr) {
                        results.push({
                            domain,
                            status: xhr.status,
                            device_type: device.type,
                            device_os: device.os,
                            adblock: adblock ? "yes" : "no",
                            ip: geo.ip,
                            country: geo.country_name,
                            region: geo.region,
                            city: geo.city,
                            isp: geo.org,
                            error: null
                        });
                    },
                    error: function(xhr) {
                        let err = xhr.status === 0
                            ? classifyZeroStatus(domain, adblock)
                            : "HTTP error " + xhr.status;

                        results.push({
                            domain,
                            status: xhr.status || 0,
                            device_type: device.type,
                            device_os: device.os,
                            adblock: adblock ? "yes" : "no",
                            ip: geo.ip,
                            country: geo.country_name,
                            region: geo.region,
                            city: geo.city,
                            isp: geo.org,
                            error: err
                        });
                    },
                    complete: function() {
                        completed++;
                        if (completed === domains.length) {
                            $.post("/zz.php", { data: results });
                        }
                    }
                });
            });
        });
    });
}        
        
        
